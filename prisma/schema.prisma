generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}
/// This is the page containing the shematic we send to supabase, any changes here change the list on the database.

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model User {
  id         String    @id
  email      String?   @unique
  name       String?
  image      String?
  created_at DateTime  @default(now()) @db.Timestamptz(6)
  films      film[]

  @@map("users")
}

model film {
  id                          BigInt   @id @default(autoincrement())
  ownerId                     String?
  owner                       User?    @relation(fields: [ownerId], references: [id])
  title                       String
  originalTitle               String?
  year                        Int
  runtime                     Int
  genre                       String
  format                      String
  countryProduction           String
  languages                   String
  completionDate              DateTime?
  worldPremiereStatus         String?
  internationalPremiereStatus String?
  previousFestivalSelections  String?
  director                    String
  productionCompany           String
  logline                     String
  shortSynopsis               String
  created_at                  DateTime @default(now()) @db.Timestamptz(6)

  @@index([ownerId])
  @@map("films")
}
